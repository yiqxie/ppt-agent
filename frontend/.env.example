# 前端环境变量样例
# 默认开发态走 vite proxy，生产环境部署到 Azure 时由后端 serve 静态资源

# 后端地址（不带末尾 /），开发模式下用于代理；生产可留空，前端用相对路径
VITE_BACKEND_URL=http://localhost:8000

# 是否启用 Microsoft Entra ID 登录
VITE_AUTH_ENABLED=false
VITE_AAD_TENANT_ID=
VITE_AAD_CLIENT_ID=
# 后端 API 的 audience 与 scope，例如 api://your-app-id/access_as_user
VITE_AAD_API_SCOPE=

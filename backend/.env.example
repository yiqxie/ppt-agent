# 后端环境变量样例（复制为 .env 后修改）
ENVIRONMENT=development
DEBUG=true
APP_NAME=PPT Slide Agent
API_PREFIX=/api

# CORS（多个用逗号分隔，pydantic-settings 会以 JSON list 形式解析；本地保持默认即可）
# CORS_ORIGINS=["http://localhost:5173"]

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ppt_agent

# Azure Storage
AZURE_STORAGE_ACCOUNT=replace-with-your-storage
AZURE_CONTAINER_SCREENSHOTS=screenshots
AZURE_CONTAINER_PROMPTS=prompts
AZURE_CONTAINER_UPLOADS=uploads
# 本地开发可填 connection string；部署到 Azure 时清空，使用 Managed Identity
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;...

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://yiqxie-ai.openai.azure.com/
AZURE_OPENAI_API_KEY=replace-with-your-key
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o

# Microsoft Entra ID (Azure AD)
AUTH_ENABLED=false
AAD_TENANT_ID=
AAD_API_AUDIENCE=
AAD_REQUIRED_SCOPE=access_as_user

# 任务并发
MAX_CONCURRENT_SLIDE_JOBS=2
MAX_CONCURRENT_SLIDE_PAGES=4
